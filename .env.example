# Required — create at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — default model when the client omits `model` (moth sends Haiku from the browser).
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Sonnet/Opus in ANTHROPIC_MODEL or in client requests are rewritten to Haiku unless you set:
# ANTHROPIC_ALLOW_SONNET=true
